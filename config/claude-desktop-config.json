{
  "mcpServers": {
    "kicad_helper": {
      "command": "node",
      "args": ["dist/index.js"],
      "cwd": "/path/to/KiCAD-MCP-Server",
      "env": {
        "NODE_ENV": "production",
        "PYTHONPATH": "/path/to/kicad/lib/python3/dist-packages"
      },
      "description": "KiCAD PCB Design Assistant"
    }
  }
}
